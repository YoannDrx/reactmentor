generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Track {
  REACT
  REACT_NATIVE
  TYPESCRIPT
  FRONTEND_SYSTEMS
}

enum ContentLocale {
  FR
  EN
}

enum QuestionLevel {
  JUNIOR
  MID
  SENIOR
}

enum QuestionFormat {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  CODE_OUTPUT
  BUG_HUNT
  OPEN_ENDED
}

enum SessionMode {
  PRACTICE
  REVIEW
  MOCK_INTERVIEW
}

enum MasteryState {
  NEW
  LEARNING
  REVIEWING
  MASTERED
}

enum TranslationStatus {
  MISSING
  IN_PROGRESS
  REVIEW
  READY
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum PlaylistKind {
  MANUAL
  GENERATED
}

enum BillingPlan {
  STARTER
  MENTOR_PRO
  HIRING_SPRINT
}

enum BillingStatus {
  FREE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

enum AnalysisDepth {
  CORE
  ADVANCED
}

enum ProductAnalyticsEventName {
  ACCOUNT_CREATED
  ONBOARDING_COMPLETED
  SESSION_STARTED
  SESSION_COMPLETED
  REVIEW_LAUNCHED
  QUESTION_ANSWERED
  LESSON_VIEWED
  LESSON_CHECKPOINT_COMPLETED
  LESSON_REVIEW_QUEUED
  BOOKMARK_CREATED
  NOTE_CREATED
  UPGRADE_CLICKED
  CHECKOUT_COMPLETED
  SUBSCRIPTION_STARTED
  MOCK_COMPLETED
}

enum OperationalEventLevel {
  INFO
  WARN
  ERROR
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  role       String?
  banned     Boolean?
  banReason  String?
  banExpires DateTime?

  sessions Session[]
  accounts Account[]

  preferences      UserPreference?
  entitlement      UserEntitlement?
  attempts         Attempt[]
  questionProgress QuestionProgress[]
  skillProgress    SkillProgress[]
  bookmarks        Bookmark[]
  notes            Note[]
  playlists        Playlist[]
  trainingSessions TrainingSession[]
  analyticsEvents  ProductAnalyticsEvent[]
  operationalEvents OperationalEvent[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model UserPreference {
  id                     String         @id @default(cuid())
  userId                 String         @unique
  targetRole             String?
  targetLevel            QuestionLevel? @default(MID)
  weeklyGoal             Int            @default(30)
  preferredTracks        Track[]        @default([REACT, TYPESCRIPT])
  focusMode              String         @default("balanced")
  lifecycleEmailsEnabled Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preference")
}

model UserEntitlement {
  id                    String         @id @default(cuid())
  userId                String         @unique
  plan                  BillingPlan    @default(STARTER)
  billingStatus         BillingStatus  @default(FREE)
  moduleAccessLimit     Int?           @default(2)
  monthlyMockLimit      Int?           @default(1)
  analysisDepth         AnalysisDepth  @default(CORE)
  playlistsEnabled      Boolean        @default(false)
  sprintModeEnabled     Boolean        @default(false)
  currentPeriodStartsAt DateTime?
  currentPeriodEndsAt   DateTime?
  billingCustomerId     String?        @unique
  billingSubscriptionId String?        @unique
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_entitlement")
}

model LearningModule {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String?
  description String?
  summary     String?
  order       Int           @default(0)
  track       Track
  level       QuestionLevel
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  skills       Skill[]
  questions    Question[]
  translations LearningModuleTranslation[]

  @@index([status])
  @@map("learning_module")
}

model Skill {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String?
  description String?
  moduleId    String
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  module           LearningModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questionsPrimary Question[]         @relation("PrimarySkill")
  questionLinks    QuestionSkill[]
  progress         SkillProgress[]
  translations     SkillTranslation[]

  @@index([status])
  @@map("skill")
}

model Question {
  id               String         @id @default(cuid())
  slug             String         @unique
  moduleId         String
  primarySkillId   String
  difficulty       Int
  level            QuestionLevel
  format           QuestionFormat
  estimatedTimeSec Int?
  sourceType       String?
  version          Int            @default(1)
  prompt           String?
  explanation      String?
  takeaways        Json?
  status           ContentStatus  @default(PUBLISHED)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  module          LearningModule           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  primarySkill    Skill                    @relation("PrimarySkill", fields: [primarySkillId], references: [id], onDelete: Restrict)
  options         QuestionOption[]
  skillLinks      QuestionSkill[]
  pitfallLinks    QuestionPitfallTag[]
  attempts        Attempt[]
  progress        QuestionProgress[]
  bookmarks       Bookmark[]
  notes           Note[]
  playlistItems   PlaylistItem[]
  collectionItems QuestionCollectionItem[]
  sessionItems    TrainingSessionItem[]
  translations    QuestionTranslation[]

  @@index([status])
  @@map("question")
}

model QuestionOption {
  id          String   @id @default(cuid())
  questionId  String
  label       String?
  explanation String?
  isCorrect   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  question     Question                    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  translations QuestionOptionTranslation[]

  @@map("question_option")
}

model LearningModuleTranslation {
  id          String            @id @default(cuid())
  moduleId    String
  locale      ContentLocale
  status      TranslationStatus @default(READY)
  title       String
  description String
  summary     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  module LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, locale])
  @@map("learning_module_translation")
}

model SkillTranslation {
  id          String            @id @default(cuid())
  skillId     String
  locale      ContentLocale
  status      TranslationStatus @default(READY)
  title       String
  description String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, locale])
  @@map("skill_translation")
}

model QuestionTranslation {
  id                   String            @id @default(cuid())
  questionId           String
  locale               ContentLocale
  status               TranslationStatus @default(READY)
  prompt               String
  explanation          String
  takeaways            Json?
  tlDr                 String?
  shortAnswer          String?
  lessonBody           String?
  commonMistakes       Json?
  exampleTitle         String?
  exampleCode          String?
  exampleLanguage      String?
  exampleExplanation   String?
  estimatedReadMinutes Int?
  contextData          Json?
  interviewSignal      String?
  verbalizePoints      Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, locale])
  @@map("question_translation")
}

model QuestionCollection {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String?
  description String?
  summary     String?
  order       Int           @default(0)
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items        QuestionCollectionItem[]
  translations QuestionCollectionTranslation[]

  @@index([status])
  @@map("question_collection")
}

model QuestionCollectionTranslation {
  id           String            @id @default(cuid())
  collectionId String
  locale       ContentLocale
  status       TranslationStatus @default(READY)
  title        String
  description  String
  summary      String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  collection QuestionCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, locale])
  @@map("question_collection_translation")
}

model QuestionCollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  questionId   String
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  collection QuestionCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  question   Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, questionId])
  @@index([collectionId, order])
  @@map("question_collection_item")
}

model QuestionOptionTranslation {
  id          String            @id @default(cuid())
  optionId    String
  locale      ContentLocale
  status      TranslationStatus @default(READY)
  label       String
  explanation String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  option QuestionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, locale])
  @@map("question_option_translation")
}

model QuestionSkill {
  questionId String
  skillId    String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([questionId, skillId])
  @@map("question_skill")
}

model PitfallTag {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questionLinks QuestionPitfallTag[]

  @@map("pitfall_tag")
}

model QuestionPitfallTag {
  questionId   String
  pitfallTagId String

  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  pitfallTag PitfallTag @relation(fields: [pitfallTagId], references: [id], onDelete: Cascade)

  @@id([questionId, pitfallTagId])
  @@map("question_pitfall_tag")
}

model TrainingSession {
  id        String      @id @default(cuid())
  userId    String
  mode      SessionMode
  config    Json?
  score     Int?
  startedAt DateTime    @default(now())
  endedAt   DateTime?

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    TrainingSessionItem[]
  attempts Attempt[]

  @@map("training_session")
}

model TrainingSessionItem {
  id         String   @id @default(cuid())
  sessionId  String
  questionId String
  order      Int
  createdAt  DateTime @default(now())

  session  TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@map("training_session_item")
}

model Attempt {
  id                String      @id @default(cuid())
  userId            String
  questionId        String
  sessionId         String?
  selectedOptionIds String[]    @default([])
  responseData      Json?
  reviewData        Json?
  isCorrect         Boolean?
  reviewedAt        DateTime?
  timeSpentMs       Int?
  mode              SessionMode
  createdAt         DateTime    @default(now())

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session  TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("attempt")
}

model QuestionProgress {
  id                 String       @id @default(cuid())
  userId             String
  questionId         String
  ease               Float        @default(2.3)
  intervalDays       Int          @default(1)
  streakCorrect      Int          @default(0)
  reviewCount        Int          @default(0)
  lapseCount         Int          @default(0)
  lastOutcomeCorrect Boolean?
  lastAttemptAt      DateTime?
  nextReviewAt       DateTime?
  masteryState       MasteryState @default(NEW)
  lessonViews        Int          @default(0)
  lastLessonViewedAt DateTime?
  lessonCheckpointAttempts Int    @default(0)
  lessonCheckpointPassCount Int   @default(0)
  lastLessonCheckpointAt DateTime?
  lastLessonCheckpointPassed Boolean?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextReviewAt])
  @@map("question_progress")
}

model SkillProgress {
  id                    String    @id @default(cuid())
  userId                String
  skillId               String
  masteryScore          Int       @default(0)
  masteryCap            Int       @default(0)
  correctRate           Float     @default(0)
  coverageCount         Int       @default(0)
  recentAttemptCount    Int       @default(0)
  uniqueQuestionCount   Int       @default(0)
  uniqueDifficultyCount Int       @default(0)
  recentFailureCount    Int       @default(0)
  confidenceScore       Int       @default(0)
  signalDetails         Json?
  lastAttemptAt         DateTime?
  lastUpdatedAt         DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("skill_progress")
}

model Playlist {
  id          String       @id @default(cuid())
  userId      String
  name        String
  description String?
  kind        PlaylistKind @default(MANUAL)
  mode        SessionMode  @default(PRACTICE)
  sourceKey   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PlaylistItem[]

  @@index([userId, updatedAt])
  @@map("playlist")
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  questionId String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([playlistId, questionId])
  @@index([playlistId, order])
  @@map("playlist_item")
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("bookmark")
}

model Note {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("note")
}

model ProductAnalyticsEvent {
  id                String                    @id @default(cuid())
  userId            String?
  name              ProductAnalyticsEventName
  source            String?
  sessionMode       SessionMode?
  billingPlan       BillingPlan?
  locale            ContentLocale?
  trainingSessionId String?
  questionId        String?
  moduleSlug        String?
  metadata          Json?
  occurredAt        DateTime                  @default(now())
  createdAt         DateTime                  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, occurredAt])
  @@index([userId, occurredAt])
  @@index([sessionMode, occurredAt])
  @@index([billingPlan, occurredAt])
  @@map("product_analytics_event")
}

model OperationalEvent {
  id         String                @id @default(cuid())
  userId     String?
  source     String
  eventType  String
  level      OperationalEventLevel @default(INFO)
  status     String?
  message    String?
  metadata   Json?
  occurredAt DateTime              @default(now())
  createdAt  DateTime              @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([source, occurredAt])
  @@index([level, occurredAt])
  @@index([status, occurredAt])
  @@map("operational_event")
}
